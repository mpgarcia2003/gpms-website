 Cleaning in Yonkers","icon":"school"},{"href":"/locations/new-york/yonkers/church-cleaning/","label":"Church Cleaning in Yonkers","icon":"church"},{"href":"/locations/new-york/yonkers/medical-office-cleaning/","label":"Medical Office Cleaning in Yonkers","icon":"medical"},{"href":"/locations/new-york/bronx/office-cleaning/","label":"Office Cleaning in Bronx","icon":"building"},{"href":"/locations/new-york/manhattan/office-cleaning/","label":"Office Cleaning in Manhattan","icon":"building"},{"href":"/locations/new-york/brooklyn/office-cleaning/","label":"Office Cleaning in Brooklyn","icon":"building"}]}]],null],null],null]},[null,["$","$L4",null,{"parallelRouterKey":"children","segmentPath":["children","locations","children","$5","children","$6","children","$7","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L8",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L4",null,{"parallelRouterKey":"children","segmentPath":["children","locations","children","$5","children","$6","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L8",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L4",null,{"parallelRouterKey":"children","segmentPath":["children","locations","children","$5","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L8",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L4",null,{"parallelRouterKey":"children","segmentPath":["children","locations","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L8",null,{}],"templateStyles":"$undefined","templateScripts":"$und